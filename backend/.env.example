GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here
LLM_PROVIDER=anthropic
LLM_MODEL_NAME=claude-haiku-4-5
ENABLE_QUERY_REWRITE=true

# Embeddings / retrieval (Voyage is the only supported provider; Pinecone is required)
EMBEDDING_PROVIDER=voyage
VOYAGE_EMBEDDING_MODEL_NAME=voyage-3.5
PINECONE_INDEX_NAME=campus-codex
PINECONE_SHARED_NAMESPACE=shared_kb
PINECONE_BENCHMARK_NAMESPACE=benchmark
RERANKER_PROVIDER=voyage
VOYAGE_RERANKER_MODEL_NAME=rerank-2.5
RETRIEVAL_CANDIDATE_K=15
RERANKED_TOP_K=5

# Paths
PDF_PATH=../data/raw/student_manual_2019.pdf

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
